{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "devflow": {
      "description": "Devflow execution agent that communicates workflow state only through Devflow HTTP tools and must never publish or exfiltrate repository code.",
      "steps": 40,
      "permission": {
        "bash": {
          "*": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "task": {
          "*": "deny"
        },
        "skill": {
          "*": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "external_directory": {
          "*": "allow"
        }
      }
    }
  }
}
