# Jira polling
JIRA_BASE_URL=https://example.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_EPIC_KEY=
JIRA_TODO_STATUS=To Do
JIRA_IN_PROGRESS_STATUS=In Progress
JIRA_BLOCKED_STATUS=Blocked
JIRA_REVIEW_STATUS=To Review
JIRA_VALIDATE_STATUS=To Validate
JIRA_DONE_STATUS=Done
JIRA_POLL_INTERVAL_MINUTES=1
JIRA_POLL_MAX_RESULTS=50

# GitHub polling and publication
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_DEFAULT_BASE_BRANCH=develop
GITHUB_POLL_INTERVAL_MINUTES=1
GITHUB_COMMIT_USER_NAME=Devflow Bot
GITHUB_COMMIT_USER_EMAIL=devflow@example.local

# GitHub repositories managed by Devflow.
# Add as many indexed entries as needed.
DEVFLOW_GITHUB_REPOSITORIES_0_NAME=my-org/repo-a
DEVFLOW_GITHUB_REPOSITORIES_0_BASE_BRANCH=main
DEVFLOW_GITHUB_REPOSITORIES_1_NAME=my-org/repo-b
DEVFLOW_GITHUB_REPOSITORIES_1_BASE_BRANCH=main

# OpenCode / model providers
OPENCODE_MODEL=
OPENCODE_SMALL_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COPILOT_GITHUB_TOKEN=
