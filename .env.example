# Jira polling
JIRA_BASE_URL=https://example.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_EPIC_KEY=
JIRA_TODO_STATUS=To Do
JIRA_IN_PROGRESS_STATUS=In Progress
JIRA_BLOCKED_STATUS=Blocked
JIRA_REVIEW_STATUS=To Review
JIRA_VALIDATE_STATUS=To Validate
JIRA_DONE_STATUS=Done
JIRA_POLL_INTERVAL_MINUTES=1
JIRA_POLL_MAX_RESULTS=50

# GitHub polling and publication
# Authentication: set GITHUB_TOKEN for PAT mode, or GITHUB_APP_* for GitHub App mode.
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_DEFAULT_BASE_BRANCH=develop
GITHUB_POLL_INTERVAL_MINUTES=1
GITHUB_COMMIT_USER_NAME=PANDA Bot
GITHUB_COMMIT_USER_EMAIL=panda@example.local

# GitHub repositories managed by PANDA.
# Add as many indexed entries as needed.
PANDA_GITHUB_REPOSITORIES_0_NAME=my-org/repo-a
PANDA_GITHUB_REPOSITORIES_0_BASE_BRANCH=main
PANDA_GITHUB_REPOSITORIES_1_NAME=my-org/repo-b
PANDA_GITHUB_REPOSITORIES_1_BASE_BRANCH=main

# OpenCode / model providers
AGENT_MAX_RUN_DURATION_MINUTES=15
AGENT_STALE_TIMEOUT_BUFFER_MINUTES=5
OPENCODE_MODEL=
OPENCODE_SMALL_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COPILOT_GITHUB_TOKEN=

# AWS Bedrock via LLM Hub (Azure SP → STS AssumeRoleWithWebIdentity)
# Set these to use Bedrock models (e.g. OPENCODE_MODEL=bedrock/us.anthropic.claude-sonnet-4-6-v1)
AWS_REGION=
LLM_HUB_CLIENT_ID=
LLM_HUB_CLIENT_SECRET=
LLM_HUB_TENANT_ID=
LLM_HUB_ARN=
LLM_HUB_RESOURCE=
